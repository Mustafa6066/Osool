# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ═══════════════════════════════════════════════════════════════
# AI API Keys
# ═══════════════════════════════════════════════════════════════

# OpenAI API Key (for AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════════

NODE_ENV=development
API_BASE_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════
# Production Configuration (Osool Platform)
# ═══════════════════════════════════════════════════════════════

# MLOps Configuration
MLOPS_INFERENCE_URL=http://localhost:8080/v1/models/xgboost:predict

# Payment Gateway (Paymob)
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_paymob_integration_id
PAYMOB_WEBHOOK_SECRET=your_paymob_webhook_secret
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret

NEXT_PUBLIC_API_URL=https://api.osool.com

# ═══════════════════════════════════════════════════════════════
# CRITICAL BACKEND VARIABLES (Added for Production Readiness)
# ═══════════════════════════════════════════════════════════════

# Database connection string (PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/osool

# JWT secret for authentication tokens (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_here

# Admin API key for protected endpoints (generate with: openssl rand -hex 32)
ADMIN_API_KEY=your_admin_api_key_here

# Environment (development, staging, production)
ENVIRONMENT=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# COMMUNICATION SERVICES (Required for auth features)
# ═══════════════════════════════════════════════════════════════

# Twilio for phone OTP verification
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid for email verification and password reset
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@osool.com

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION PROVIDERS
# ═══════════════════════════════════════════════════════════════

# Google OAuth for social login
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ═══════════════════════════════════════════════════════════════
# MONITORING & OBSERVABILITY
# ═══════════════════════════════════════════════════════════════

# Sentry for error tracking
SENTRY_DSN=https://...@sentry.io/...

# Redis for caching and session management
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════
# MLOPS CONFIGURATION
# ═══════════════════════════════════════════════════════════════

MLOPS_INFERENCE_URL=http://localhost:8080/v1/models/xgboost:predict
